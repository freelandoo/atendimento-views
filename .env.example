# ============================================================
# PJ Codeworks Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env real
# ============================================================

# IA — Provider principal (OpenAI) e fallback (Anthropic)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_KEY=

# WhatsApp — Evolution API
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=PJ

# Banco de dados
DATABASE_URL=postgresql://evolution:evolution@localhost:5432/evolution_api

# Servidor
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo

# Segurança
REPROCESS_SECRET=
WEBHOOK_SECRET=
JWT_SECRET=
SESSION_SECRET=

# Dashboard / Auth
DASHBOARD_ADMIN_EMAIL=
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_SESSION_TTL_MS=28800000

# Admin inicial SaaS
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Empresa padrão (PJ Codeworks)
DEFAULT_COMPANY_NAME=PJ Codeworks
DEFAULT_COMPANY_SLUG=pj-codeworks

# Frontend (URL do app Next.js para CORS)
FRONTEND_URL=http://localhost:3001

# Operadores
OPERATOR_WHATSAPP=

# Google APIs (opcionais)
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=
GOOGLE_PLACES_API_KEY=

# Telegram (alertas de handoff — opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Whisper (transcrição de áudio — opcional)
WHISPER_SERVICE_URL=http://whisper-service:9000

# Feature flags
CLAUDE_WEB_SEARCH=true
FOLLOWUP_AUTO_ENABLED=true
