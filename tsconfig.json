{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "index.js",
    "src/**/*.js",
    "src/**/*.ts",
    "test/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
