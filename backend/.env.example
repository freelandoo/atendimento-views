# =============================================================================
# PJ Codeworks Agent — referência de variáveis de ambiente
# Copie para .env (NUNCA versione o .env) e preencha os valores.
# [OBRIGATÓRIA] = validada no boot (index.js -> validarSecretsBoot); sem ela o
# processo aborta. As demais têm default no código e são opcionais.
# =============================================================================

# --- Provedor de IA (ao menos UMA chave é OBRIGATÓRIA) ----------------------
# Basta uma das chaves abaixo (Anthropic OU OpenAI). As duas habilitam fallback.
ANTHROPIC_KEY=
ANTHROPIC_API_KEY=
OPENAI_KEY=
OPENAI_API_KEY=
# Provedor primário e modelo (o fallback é derivado automaticamente).
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
# Aliases opcionais aceitos pelo código (caso prefira nomes por provedor):
# DEFAULT_AI_PROVIDER=
# DEFAULT_AI_MODEL=
# DEFAULT_OPENAI_MODEL=
# DEFAULT_ANTHROPIC_MODEL=

# --- Segredos de rota (admin/webhook) ---------------------------------------
REPROCESS_SECRET=            # [OBRIGATÓRIA] mín. 8 chars — protege /dashboard/* e /webhook
WEBHOOK_SECRET=              # opcional — habilita x-webhook-secret / Authorization: Bearer no /webhook

# --- Admin inicial do dashboard ---------------------------------------------
DASHBOARD_ADMIN_EMAIL=       # [OBRIGATÓRIA] e-mail do primeiro admin
DASHBOARD_ADMIN_PASSWORD=    # [OBRIGATÓRIA] mín. 12 chars
DASHBOARD_SESSION_TTL_MS=28800000   # opcional — TTL da sessão (default 8h)

# --- Evolution API (WhatsApp) -----------------------------------------------
EVOLUTION_API_KEY=           # [OBRIGATÓRIA]
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=PJ

# --- Banco de dados ----------------------------------------------------------
DATABASE_URL=postgresql://evolution:evolution@localhost:5432/evolution_api
POOL_MAX=2                   # opcional — máx. de conexões no pool (default 2; Railway free ~8 limit p/ todas replicas)
POOL_CONNECTION_TIMEOUT_MS=3000   # opcional — espera por conexão livre (default 3000ms)
POOL_IDLE_TIMEOUT_MS=10000        # opcional — fecha conexão ociosa após N ms (default 10000ms)

# --- Servidor / ambiente -----------------------------------------------------
PORT=3000
NODE_ENV=                    # 'production' ativa cookie Secure e SSL do banco
TZ=America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo
LOG_LEVEL=info

# --- Operador / alertas ------------------------------------------------------
OPERATOR_WHATSAPP=           # JID/numero do operador (também aceita VICTOR_WHATSAPP)
# VICTOR_WHATSAPP=
TELEGRAM_BOT_TOKEN=          # opcional — alertas de handoff via Telegram
TELEGRAM_CHAT_ID=
DASHBOARD_URL=               # opcional — URL base do painel p/ link no alerta (ex.: https://app.exemplo.com); sem ela usa RAILWAY_PUBLIC_DOMAIN e, por fim, o padrão de produção pjcodeworks-agent-production.up.railway.app

# --- Google (prospecção / busca) --------------------------------------------
GOOGLE_PLACES_API_KEY=       # busca de prospects (também aceita GOOGLE_MAPS_API_KEY)
# GOOGLE_MAPS_API_KEY=
GOOGLE_CSE_KEY=              # busca complementar (Custom Search)
GOOGLE_CSE_ID=

# --- Flags de comportamento (opcionais) -------------------------------------
# NEXT_ACTION_ORCHESTRATOR_ENABLED removida: o orquestrador novo + IA-primaria
# sao sempre ativos no codigo (sem rollback por flag).
PROSPECTING_INTELLIGENCE_ENABLED=0   # default desligado (esteira inteligente fase 1)
SANITIZAR_CPF_RESPOSTA=0             # default desligado

# --- Tuning de IA (opcionais; têm default e limites no código) --------------
# AI_TIMEOUT_MS=30000              # opcional — timeout do provider primario (default 30000ms); callers podem override via input.timeoutMs
# AI_FALLBACK_TIMEOUT_MS=30000     # opcional — timeout do provider de fallback (default herda do primario); cap pior caso primary+fallback
# AI_STRUCTURED_OUTPUTS=on         # opcional — Structured Outputs (json_schema strict) no caminho OpenAI; "off" desliga (volta a json_object). Default ligado, com fallback automatico se a API recusar o schema.
# AI_REPAIR_MAX_RETRIES=1          # opcional — nº máx. de retries de reparo quando a IA não emite reuniao_escolha em turno de agenda (default 1; 0 desliga). Cada retry = +1 chamada LLM, logado como [ai-repair].
# REUNIAO_BUFFER_MIN=30            # opcional — folga (min) exigida ENTRE reuniões p/ uma não atropelar a próxima (default 30; 0 desliga). Afeta oferta, validação e criação de reunião.
# PROSPEC_MERCADO_IA_RETRIES=3     # opcional — nº de tentativas da IA ao escolher o mercado do dia (nicho+cidade) na prospecção (default 3). SEM fallback p/ rotação antiga: se todas falharem, a rodada do dia é ABORTADA (execução marcada 'falhou') e o erro fica logado (logger.error) no Railway.
# PROSPEC_EXTRAIR_EMAIL_SITE=on    # opcional — na coleta Google Places, raspa o SITE do lead atrás de um e-mail e grava (best-effort, concorrência limitada, não bloqueia a coleta). 'off' desliga. Usa LINK_BIO_TIMEOUT_MS como timeout por fetch.
# --- Atribuição Meta Ads (Click-to-WhatsApp / Conversions API) ---
# META_QUALIFIED_LEAD_MIN=60       # opcional — score mínimo (0-100) p/ um lead virar "lead qualificado" (LeadSubmitted) enviado à Meta (default 60). Botão de qualidade: subir = leads mais quentes, menos volume. Reunião agendada também qualifica.
# META_DATASET_ID=                 # ID do conjunto de dados (Events Manager) que recebe os eventos de conversão. (ex.: 1572278814315441) — usado no envio à Conversions API.
# META_CAPI_TOKEN=                 # token de acesso da API de Conversões (usuário de sistema, ads_management). SECRETO — só no Railway. Sem ele o envio à Meta fica desligado.
# META_PAGE_ID=                    # ID da Página do Facebook que roda os anúncios CTWA (ex.: 899608136565523). OBRIGATÓRIO p/ a CAPI aceitar: business_messaging exige page_id OU whatsapp_business_account_id no user_data (subcode 2804116).
# META_WABA_ID=                    # alternativa ao META_PAGE_ID — ID da conta do WhatsApp Business. Usado só se META_PAGE_ID não estiver setado.
# META_CAPI_API_VERSION=v21.0      # opcional — versão da Graph API usada no envio (default v21.0).
# META_CAPI_TEST_CODE=             # opcional — se setado, manda como evento de TESTE (aparece em "Testar eventos" do Gerenciador de Eventos). Tirar p/ produção.
# META_CAPI_PURCHASE_ENABLED=off   # opcional — liga o evento Purchase (venda). Default desligado (só LeadSubmitted). Quando ligar, manda o valor da venda. (CTWA business_messaging só aceita LeadSubmitted + Purchase.)
# CLAUDE_TIMEOUT_MS=45000
# CLAUDE_AUXILIAR_TIMEOUT_CAP_MS=600000
# CLAUDE_WEB_SEARCH=1
# CLAUDE_WEB_SEARCH_MAX_USES=5
# CLAUDE_WEB_SEARCH_PAUSE_MAX=8
# CLAUDE_WEB_SEARCH_TIMEOUT_MS=
# CLAUDE_OVERLAY_TIMEOUT_MS=
# CLAUDE_OVERLAY_TIMING_TIMEOUT_MS=
# HISTORICO_CLAUDE_MAX_MSGS=20
# WEBHOOK_REPLY_DEBOUNCE_MS=2500

# --- Estimativa de custo de LLM (opcionais; dashboard de custos) ------------
# LLM_ESTIMATE_INPUT_PER_MTOK_USD=
# LLM_ESTIMATE_OUTPUT_PER_MTOK_USD=
# LLM_USD_BRL=

# --- Worker de jobs / silence watcher (opcionais) ---------------------------
# JOB_WORKER_POLL_MS=1500
# JOB_WORKER_LOCK_MS=120000
# JOB_MAX_ATTEMPTS=5
# SILENCE_WATCHER_INTERVAL_MS=60000
# SILENCE_TRIGGER_MINUTES=60
# REPLICA_ID=                 # identifica a réplica em deploy multi-instância

# --- Follow-up automático (opcionais; têm default e limites no código) ------
# FOLLOWUP_AUTO_SEQ_PADRAO=3
# FOLLOWUP_AUTO_SEQ_PRIMEIRO_CONTATO=1
# FOLLOWUP_AUTO_SEQ_PROPOSTA_ENVIADA=5
# FOLLOWUP_AUTO_SEQ_NEGOCIACAO=5
# FOLLOWUP_AUTO_BUSINESS_TZ=America/Sao_Paulo
# FOLLOWUP_AUTO_BUSINESS_START_HOUR=8
# FOLLOWUP_AUTO_BUSINESS_END_HOUR=20
# FOLLOWUP_AUTO_DELAY_SEQ1_H=2
# FOLLOWUP_AUTO_DELAY_SEQ2_H=24
# FOLLOWUP_AUTO_DELAY_SEQ3_H=72
# FOLLOWUP_AUTO_DELAY_SEQ4_H=120
# FOLLOWUP_AUTO_DELAY_SEQ5_H=168
# FOLLOWUP_AUTO_DELAY_SEQ6_H=168
# FOLLOWUP_AUTO_DELAY_SEQ7_H=168

# --- Prospecção (opcionais) --------------------------------------------------
# AUTO_PROSPECCAO_TIMEZONE=America/Sao_Paulo
# PROSPECCAO_COMERCIAL_INICIO=
# PROSPECCAO_COMERCIAL_FIM=

# --- Captação social (Bright Data: Instagram agora, LinkedIn no mesmo motor) --
# Sem BRIGHTDATA_API_TOKEN o canal de captação fica DESLIGADO (worker não roda).
# BRIGHTDATA_API_TOKEN=
# dataset_id de cada coleta. IDs CONFIRMADOS na conta (jun/2026) por teste real:
#   Instagram - Profiles  = gd_l1vikfch901nx3by4  (coleta por username/URL; traz
#                           biography, external_url[], email_address, followers,
#                           business_category_name — NÃO traz telefone)
#   LinkedIn people prof. = gd_l1viktl72bvl7bjuj0
#   LinkedIn company info = gd_l1vikfnt1wgvvqz95w
# ATENÇÃO: descoberta por HASHTAG não está disponível nesta conta (os coletores
# on-demand só descobrem por user_name/url; datasets estáticos de hashtag não são
# da conta). Deixe *_DESCOBERTA VAZIO -> o motor opera em modo "lista de @perfis"
# (o campo `termo` da campanha vira lista de usernames separados por vírgula).
# BRIGHTDATA_DATASET_IG_DESCOBERTA=
# BRIGHTDATA_DATASET_IG_PERFIS=gd_l1vikfch901nx3by4
# BRIGHTDATA_DATASET_LI_DESCOBERTA=
# BRIGHTDATA_DATASET_LI_PERFIS=gd_l1viktl72bvl7bjuj0
# Teto diário de registros consumidos na conta inteira (free tier = 5000/mês ≈ 166/dia).
# BRIGHTDATA_CAPTACAO_TETO_DIARIO=166
# Seguir o link da bio atrás de email/WhatsApp (default off global; a campanha pode
# ligar por conta dela — recomendado ON, recupera muito contato de linktr.ee/etc).
# BRIGHTDATA_SEGUIR_LINK_BIO=off
# Descoberta de perfis por NICHO usa o Google CSE já existente (GOOGLE_CSE_KEY/ID).
# Bola de neve via related_accounts: profundidade máx. (0=só sementes, 1=relacionados).
# CAPTACAO_SNOWBALL_MAX_NIVEL=1
# Timeouts e intervalo do worker (ms).
# BRIGHTDATA_TIMEOUT_MS=60000
# LINK_BIO_TIMEOUT_MS=8000
# CAPTACAO_WORKER_POLL_MS=60000

# --- Canal de e-mail para leads sociais (Fase futura; dados já gravados) ------
# Sem as três variáveis o canal fica DESATIVADO (registra, não envia). Provider
# estilo Resend (POST com {from,to,subject,html}).
# EMAIL_PROVIDER_API_URL=https://api.resend.com/emails
# EMAIL_PROVIDER_API_KEY=
# EMAIL_FROM=
# EMAIL_TIMEOUT_MS=20000

# --- SaaS multiempresa (camada /api/* + frontend Next.js) --------------------
# Autenticação JWT das rotas /api/* (Bearer token). Defina um segredo forte em
# produção — o default 'CHANGE_ME_IN_PRODUCTION' NÃO deve ir para o ar.
JWT_SECRET=
# Validade do token JWT (ex.: 24h, 7d). Default: 24h.
# JWT_EXPIRES_IN=24h
# Primeiro admin SaaS (schema app.usuarios). Se ausentes, caem para
# DASHBOARD_ADMIN_EMAIL/DASHBOARD_ADMIN_PASSWORD; sem nenhum, o seed é pulado.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NOME=Admin
# Origem permitida no CORS para o frontend Next.js (Vercel/local). Sem ela,
# o CORS libera qualquer origem (origin: true).
FRONTEND_URL=http://localhost:3001

# --- "Rodar leads" (disparo manual da saudação no Banco de Leads) ------------
# Throttle anti-ban do disparo manual (src/services/rodar-leads.js).
# RODAR_LEADS_MAX_LOTE=15           # máx de leads por rodada
# RODAR_LEADS_COOLDOWN_MIN=5        # minutos entre rodadas por instância
# RODAR_LEADS_TETO_DIARIO=40        # teto diário de disparos por instância (0 = sem teto)
# RODAR_LEADS_DELAY_MIN_MS=12000    # delay aleatório mínimo entre envios da rodada
# RODAR_LEADS_DELAY_MAX_MS=20000    # delay aleatório máximo entre envios da rodada
# Trava automática de 15 dias quando a conversa morre/rejeita (src/services/lead-lock.js).
# LEAD_LOCK_DIAS=15                 # dias de bloqueio após morte/rejeição
# LEAD_MORTA_DIAS=5                 # dias sem resposta para considerar a conversa "morta"
# LEAD_LOCK_WORKER_MS=3600000       # intervalo do worker de auto-lock (default 1h)
